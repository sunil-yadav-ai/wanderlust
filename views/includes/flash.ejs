<% if( success && success.length){ %>
    <div class="alert alert-success offset-3 col-6" role="alert">
        
        <%= success %>
        <button type="button" class="btn-close offset-9" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

<% } %>

<% if( error && error.length){ %>
    <div class="alert alert-danger offset-3 col-6" role="alert">
        <%= error %>
        <button type="button" class="btn-close offset-7" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

<% } %>