<% if( success && success.length){ %>
    <div class="alert alert-success offset-4 col-4" role="alert">
        
        <%= success %>
        <button type="button" class="btn-close offset-6" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

<% } %>

<% if( error && error.length){ %>
    <div class="alert alert-danger offset-4 col-4" role="alert">
        <%= error %>
        <button type="button" class="btn-close offset-1" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

<% } %>