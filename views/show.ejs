








  










<style>
  body {
    overflow-x: hidden;
  }

  #map {
    width: 100%;
    height: 400px;
  }

  @media (max-width: 768px) {
    #map {
      height: 250px;
    }
  }
</style>

<%- layout("layouts/boilerplate") -%>

<script>
  window.placesData = <%- JSON.stringify(item.coordinates) %>;
</script>

<div class="container mt-3">

  <!-- TITLE -->
  <div class="row">
    <div class="col-12 col-md-8 mx-auto">
      <h4><b><%= item.title %></b></h4>
    </div>
  </div>

  <!-- CARD -->
  <div class="row">
    <div class="col-12 col-md-8 col-lg-6 mx-auto mb-3">
      <div class="card">
        <img src="<%= item.image.url %>" 
             class="card-img-top img-fluid" 
             alt="listing_img">

        <div class="card-body">
          <p><i>Owner: <%= item.owner.username %></i></p>
          <p><%= item.description %></p>
          <p>&#8377 <%= item.price.toLocaleString("en-In") %></p>
          <p><%= item.location %></p>
          <p><%= item.country %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- BUTTONS -->
  <% if(Current && item.owner._id.equals(Current._id)){ %>
  <div class="row">
    <div class="col-12 col-md-8 mx-auto d-flex gap-2 mb-3">
      <form method="get" action="/listing/<%= item._id %>/edit">
        <button class="btn Edit-btn">Edit</button>
      </form>

      <form method="POST" action="/listing/<%= item._id %>?_method=DELETE">
        <button class="btn btn-dark">Delete</button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- REVIEW FORM -->
  <% if(Current){ %>
  <div class="row">
    <div class="col-12 col-md-8 mx-auto mb-3">
      <hr>
      <h4>Leave a review</h4>

      <form action="/listing/<%= item._id %>/review" method="post" class="needs-validation">

        <div class="mb-3">
          <label class="form-label">Comment</label>
          <textarea name="review[comment]" class="form-control" required></textarea>
        </div>

        <button class="btn btn-outline-dark ">Submit</button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- REVIEWS -->
  <% if(item.reviews.length > 0) { %>
  <div class="row">
    <div class="col-12 col-md-8 mx-auto">
      <hr>
      <h4>All Reviews</h4>

      <div class="row">
        <% for(review of item.reviews){ %>
        <div class="col-12 col-md-6 mb-3">
          <div class="card h-100">
            <img src="https://via.placeholder.com/300" class="img-fluid">
            <div class="card-body">
              <h5><%= review.author.username %></h5>
              <p><%= review.comment %></p>

              <% if(Current && Current._id.equals(review.author._id)) { %>
              <form method="post" action="/listing/<%= item._id %>/review/<%= review._id %>?_method=DELETE">
                <button class="btn btn-dark btn-sm">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% } %>
      </div>

    </div>
  </div>
  <% } %>

  <!-- MAP -->
  <div class="row">
    <div class="col-12 col-md-8 mx-auto mb-3">
      <div id="map"></div>
    </div>
  </div>

</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="/js/map.js"></script>
 







































