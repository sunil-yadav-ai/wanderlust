








  










<style>
  body {
    overflow-x: hidden;
  }

  #map {
    width: 100%;
    height: 400px;
  }

  @media (max-width: 768px) {
    #map {
      height: 250px;
    }
  }
</style>

<%- layout("layouts/boilerplate") -%>

<script>
  window.placesData = <%- JSON.stringify(item.coordinates) %>;
</script>

<div class="container mt-3">

  <!-- TITLE -->
  <div class="row">
    <div class="col-12 col-md-8 mx-auto">
      <h4><b><%= item.title %></b></h4>
    </div>
  </div>

  <!-- CARD -->
  <div class="row">
    <div class="col-12 col-md-8 col-lg-6 mx-auto mb-3">
      <div class="card">
        <img src="<%= item.image.url %>" 
             class="card-img-top img-fluid" 
             alt="listing_img">

        <div class="card-body">
          <p><i>Owner: <%= item.owner.username %></i></p>
          <p><%= item.description %></p>
          <p>&#8377 <%= item.price.toLocaleString("en-In") %></p>
          <p><%= item.location %></p>
          <p><%= item.country %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- BUTTONS -->
  <% if(Current && item.owner._id.equals(Current._id)){ %>
  <div class="row">
    <div class="col-12 col-md-8 mx-auto d-flex gap-2 mb-3">
      <form method="get" action="/listing/<%= item._id %>/edit">
        <button class="btn Edit-btn">Edit</button>
      </form>

      <form method="POST" action="/listing/<%= item._id %>?_method=DELETE">
        <button class="btn btn-dark">Delete</button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- REVIEW FORM -->
  <% if(Current){ %>
  <div class="row">
    <div class="col-12 col-md-8 mx-auto mb-3">

     











      <hr>
      <h4>Leave a review</h4>


      <form action="/listing/<%= item._id %>/review" method="post" class="needs-validation">
        <fieldset class="starability-slot"> <legend>Rating</legend> <!-- No rating --> <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked /> <!-- 1 star --> <input type="radio" id="rate1" name="review[rating]" value="1" /> <label for="rate1" title="Terrible">1 star</label> <!-- 2 stars --> <input type="radio" id="rate2" name="review[rating]" value="2" /> <label for="rate2" title="Not good">2 stars</label> <!-- 3 stars --> <input type="radio" id="rate3" name="review[rating]" value="3" /> <label for="rate3" title="Average">3 stars</label> <!-- 4 stars --> <input type="radio" id="rate4" name="review[rating]" value="4" /> <label for="rate4" title="Very good">4 stars</label> <!-- 5 stars --> <input type="radio" id="rate5" name="review[rating]" value="5" /> <label for="rate5" title="Amazing">5 stars</label> <!-- Focus ring --> <span class="starability-focus-ring"></span> </fieldset> 
        
        <br><br>
        <div class="mb-3">
          <label class="form-label">Comment</label>
          <textarea name="review[comment]" class="form-control" required></textarea>
        </div>

        <button class="btn btn-outline-dark ">Submit</button>
      </form>
    </div>
  </div>
  <% } %>

  

  <!-- REVIEWS -->
  <% if(item.reviews.length > 0) { %>
  <div class="row">
    <div class="col-12 col-md-8 mx-auto">
      <hr>
      <h4>All Reviews</h4>

      <div class="row">
        <% for(review of item.reviews){ %>
        <div class="col-12 col-md-6 mb-3">
          <div class="card h-100">
            <img src="https://th.bing.com/th/id/OIP.U-7XRcZLo7hxHQzo86aM_gHaE8?o=7rm=3&rs=1&pid=ImgDetMain&o=7&rm=3" class="img-fluid" height="30" width="30" style="border-radius: 50px;">
            <div class="card-body">
              <h5><%= review.author.username %></h5>
              <p class="starability-result" data-rating=<%= review.rating %>></p>
              <p><%= review.comment %></p>

              <% if(Current && Current._id.equals(review.author._id)) { %>
              <form method="post" action="/listing/<%= item._id %>/review/<%= review._id %>?_method=DELETE">
                <button class="btn btn-dark btn-sm">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% } %>
      </div>

    </div>
  </div>
  <% } %>

  <!-- MAP -->
  <div class="row">
    <div class="col-12 col-md-8 mx-auto mb-3">
      <div id="map"></div>
    </div>
  </div>

</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="/js/map.js"></script>
 










































